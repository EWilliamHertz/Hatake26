generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
}

enum Role {
  USER
  ADMIN
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String   // The primary Thumbnail
  images      String[] @default([]) // Array of the extra 19 gallery images
  isSingle    Boolean  @default(false) 
  category    String   @default("SEALED") // "MTG", "POKEMON", "MERCHANDISE"
  scryfallId  String?  
  edition     String?
  stock       Int      @default(0)
  price       Float    @default(0) // Added price for checkout
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   Int      @unique @default(autoincrement()) // Generates the unique Swish code (e.g., 48)
  customerEmail String
  customerName  String
  items         Json     // Array of items bought
  totalValue    Float
  status        String   @default("PENDING_PAYMENT") // PENDING_PAYMENT, PROCESSING, COMPLETED, CANCELLED
  createdAt     DateTime @default(now())
}

model Inquiry {
  id            String   @id @default(cuid())
  customerEmail String
  customerName  String
  message       String?
  items         Json     // Stores an array of { productId, name, quantity, basePrice, discountedPrice }
  totalValue    Float    @default(0)
  status        String   @default("PENDING") // PENDING, REVIEWED, COMPLETED
  createdAt     DateTime @default(now())
}